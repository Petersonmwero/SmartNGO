# Copy to backend/.env and fill in real values. Never commit the real .env.

# --- Django core ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=Africa/Nairobi

# --- MySQL 8 (PyMySQL driver) ---
DB_NAME=smartngo
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Copy to backend/.env and fill in real values. Never commit the real .env.

# --- Django core ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=Africa/Nairobi

# --- MySQL 8 (PyMySQL driver) ---
DB_NAME=smartngo
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# --- Email (Gmail SMTP) ---
# How to get an App Password:
#   1. myaccount.google.com → Security → enable 2-Step Verification
#   2. Security → App passwords → Create → name it "Smart NGO"
#   3. Copy the 16-character code and paste below (no spaces needed)
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=Smart NGO <your-gmail@gmail.com>

# --- URLs ---
BACKEND_BASE_URL=http://localhost:8000
# Update the port to match the one shown in your browser when Flutter is running
FLUTTER_VERIFY_SUCCESS_URL=http://localhost:60860/#/verify-success
